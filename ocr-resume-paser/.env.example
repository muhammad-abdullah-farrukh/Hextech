# Copy to `.env` and fill in. `.env` is git-ignored.

# OpenAI-compatible endpoint of your local server (e.g. vLLM).
LLM_BASE_URL=http://localhost:8000/v1
# The model name your server serves (must match what GET /v1/models reports).
LLM_MODEL=
# Most local servers ignore this; set only if yours enforces a key.
LLM_API_KEY=not-needed

# Structured-output mode. vLLM honors response_format json_schema well.
# Run scripts/probe_instructor_mode.py to confirm the best one for your model.
# One of: JSON_SCHEMA | TOOLS | JSON | MD_JSON
INSTRUCTOR_MODE=JSON_SCHEMA

# Retry knobs.
LLM_MAX_RETRIES=2          # instructor validation re-asks
LLM_RATELIMIT_ATTEMPTS=5   # tenacity attempts on transient errors
LLM_HEALTH_TIMEOUT=2.0     # seconds for the /models reachability check

# Self-verify/refine: after the first generate, the model re-checks its own JSON
# against the source and fills/fixes gaps. Total LLM calls = 1 + this. 0 disables.
LLM_REFINE_PASSES=2

# Context-window guard. Resume text is truncated if system_prompt + resume +
# max_tokens would exceed the window. Match LLM_CONTEXT_WINDOW to your server's -c.
LLM_CONTEXT_WINDOW=24576
LLM_CONTEXT_SAFETY_MARGIN=256   # absorbs estimate slack + chat-template overhead
LLM_CHARS_PER_TOKEN=3.5         # token estimate; lower = more conservative

# Sampling guards — keep small models from runaway repetition loops.
# Reasoning models (e.g. DeepSeek-R1) degenerate at temp 0 — R1 wants ~0.6.
LLM_TEMPERATURE=0.6
LLM_FREQUENCY_PENALTY=0.15
LLM_PRESENCE_PENALTY=0.0
LLM_MAX_TOKENS=4096

# Postgres persistence. Only used when you pass `--db-uri` to the CLI (or run the
# DB tests); a plain CLI run never touches the database. Matches docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://resume_parser:devpassword@localhost:5433/resume_parser
# Same container/port, separate database used only by tests/test_db_ingest.py.
TEST_DATABASE_URL=postgresql+psycopg2://resume_parser:devpassword@localhost:5433/resume_parser_test
